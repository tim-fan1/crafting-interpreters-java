fun doubleValue(value) {
  return value * 2;
}

fun isLargerThanNine(value) {
  return value > 9;
}

var list = [1,2,3,4,5,6,7,8,9];
var mappedList = map(doubleValue, list);
for (var i = 0; i < len(mappedList); i = i + 1) {
  print mappedList[i];
}

print "";
print "===";
print "";

var filteredList = filter(isLargerThanNine, mappedList);
for (var i = 0; i < len(filteredList); i = i + 1) {
  print filteredList[i];
}